# AI Surveillance System Configuration

# Flask
SECRET_KEY=your-secret-key-here
DEBUG=True

# Email Alerts (Optional - for email notifications)
ALERT_EMAIL=admin@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Camera Configuration
# Add your IP camera URLs here
# CAMERA_1=rtsp://username:password@192.168.1.100:554/stream
# CAMERA_2=http://192.168.1.101:8080/video

# Detection Thresholds
MAX_PEOPLE_COUNT=50
MIN_CLEANLINESS_SCORE=0.7
CONFIDENCE_THRESHOLD=0.5
